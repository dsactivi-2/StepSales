# OpenAI Configuration (LIVE - REAL API)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-realtime-1.5
VOICE=shimmer
MAX_OUTPUT_TOKENS=512
TEMPERATURE=0.7

# Stepstone Configuration
STEPSTONE_SERVER_PATH=/path/to/mcp-stepstone
DEFAULT_ZIP_CODE=40210
DEFAULT_RADIUS=15
REQUEST_TIMEOUT=10

# Telesales Configuration
MAX_CALL_DURATION=900
VOICE_SPEED=1.0
LOG_LEVEL=INFO

# Web Server Configuration (Optional)
PORT=8000
HOST=0.0.0.0

# CRM Integration (Optional)
CRM_ENABLED=false
CRM_API_KEY=

# ⚠️  IMPORTANT
# 1. Copy this file to .env: cp .env.example .env
# 2. Set your OPENAI_API_KEY in .env
# 3. NEVER commit .env to git (it contains secrets)
# 4. Validate config: python -c "from config import Config; Config.validate()"
