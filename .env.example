# OpenAI Configuration (LLM - Conversational AI)
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-4.1-2025-04-14
OPENAI_TEMPERATURE=0.8
OPENAI_MAX_TOKENS=512

# Telnyx Configuration (Telephony - Outbound Calls)
TELNYX_API_KEY=KEY_your-telnyx-api-key
TELNYX_CONNECTION_ID=your-connection-id
TELNYX_FROM_NUMBER=+49your-number
TELNYX_WEBHOOK_SECRET=your-webhook-secret

# Deepgram Configuration (Speech-to-Text)
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=de
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_INTERIM_RESULTS=true
DEEPGRAM_UTTERANCE_END_MS=1000
DEEPGRAM_ENDPOINTING_MS=300

# ElevenLabs Configuration (Text-to-Speech)
ELEVENLABS_API_KEY=sk_your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.68
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.22
ELEVENLABS_SPEED=0.96
ELEVENLABS_USE_SPEAKER_BOOST=true

# Stripe Configuration (Billing / Invoicing)
STRIPE_API_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Runtime Configuration
HOST=0.0.0.0
PORT=8010
LOG_LEVEL=INFO

# Persistence
DATABASE_URL=sqlite:///data/stepsales.db
TRANSCRIPT_DIR=data/transcripts

# Telesales
MAX_CALL_DURATION=900
VOICE_SPEED=1.0

# Stepstone MCP
STEPSTONE_SERVER_PATH=/path/to/mcp-stepstone
DEFAULT_ZIP_CODE=40210
DEFAULT_RADIUS=15
REQUEST_TIMEOUT=10

# CRM
CRM_ENABLED=false
CRM_API_KEY=
