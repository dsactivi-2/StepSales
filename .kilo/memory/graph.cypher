// Memory Graph Seed (idempotent)
MERGE (p:Project {id:'stepsales', name:'StepSales'})
MERGE (r:Runtime {id:'runtime-local', port:8010, env_path:'environment/.env'})
MERGE (d1:Decision {id:'mem-001', topic:'runtime-port', status:'active'})
MERGE (d2:Decision {id:'mem-002', topic:'env-file-path', status:'active'})
MERGE (rk1:Risk {id:'risk-env-drift', status:'open'})
MERGE (rk2:Risk {id:'risk-memory-stale', status:'open'})
MERGE (t1:Task {id:'task-memory-sync', status:'active'})
MERGE (t2:Task {id:'task-telnyx-setup', status:'open'})
MERGE (t3:Task {id:'task-realtime-enablement', status:'open'})
MERGE (pv1:Provider {id:'provider-telnyx', name:'Telnyx', status:'pending'})
MERGE (pv2:Provider {id:'provider-openai', name:'OpenAI', status:'active'})
MERGE (g1:Gap {id:'gap-telnyx-setup', status:'open'})
MERGE (g2:Gap {id:'gap-realtime-pending', status:'open'})

MERGE (p)-[:HAS_RUNTIME]->(r)
MERGE (p)-[:HAS_DECISION]->(d1)
MERGE (p)-[:HAS_DECISION]->(d2)
MERGE (p)-[:HAS_RISK]->(rk1)
MERGE (p)-[:HAS_RISK]->(rk2)
