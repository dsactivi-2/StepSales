MERGE (p)-[:NEXT_ACTION]->(t2)
MERGE (p)-[:NEXT_ACTION]->(t3)
MERGE (p)-[:USES_PROVIDER]->(pv1)
MERGE (p)-[:USES_PROVIDER]->(pv2)
MERGE (pv1)-[:HAS_GAP]->(g1)
MERGE (p)-[:HAS_GAP]->(g2)
MERGE (t2)-[:ADDRESSES]->(g1)
MERGE (t3)-[:ADDRESSES]->(g2)
MERGE (d2)-[:MITIGATES]->(rk1)
MERGE (t1)-[:MITIGATES]->(rk2)

